<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="utf-8">
<title>Fundamenty Powieści · Za kulisami dobrej książki</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Mulish:ital,wght@0,300;0,400;0,600;0,700;1,300&display=swap" rel="stylesheet">

<style>
  :root {
    --ink:        #0D0D0D;
    --ink-soft:   #333333;
    --ink-muted:  #666666;
    --paper:      #FFFFFF;
    --paper-mid:  #E5E5E5;
    --grad:       linear-gradient(135deg, #6B35C8 0%, #E8772A 100%);
    --grad-text:  linear-gradient(135deg, #6B35C8 0%, #E8772A 100%);
    --purple-pale: #F5F0FF;
    --radius:     8px;
    --serif: 'Lora', Georgia, serif; /* Nagłówki */
    --sans:  'Mulish', sans-serif;  /* Tekst główny */
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #2a2330;
    font-family: var(--sans);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
  }

  .doc {
    padding: 36px 0 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  .page {
    width: 210mm;
    min-height: 297mm;
    background: var(--paper);
    padding: 18mm 0 16mm; /* Margines boczny zarządzany przez kontenery */
    position: relative;
    box-shadow: 0 30px 60px -20px rgba(0,0,0,.6);
    display: flex;
    flex-direction: column;
  }
  .page::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 6px;
    background: var(--grad);
  }

  /* UKŁAD: TEKST + MARGINES NA NOTATKI */
  .content-wrapper {
    display: flex;
    flex: 1;
    padding: 0 18mm;
    gap: 15mm;
  }

  .main-text {
    flex: 2; /* Główny tekst zajmuje więcej miejsca */
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink-soft);
    text-align: justify;
  }

  .notes-sidebar {
    flex: 0.8; /* Margines na notatki */
    border-left: 1px dashed var(--paper-mid);
    padding-left: 10px;
    position: relative;
  }

  .dot-grid {
    width: 100%;
    height: 100%;
    background-image: radial-gradient(var(--paper-mid) 1.2px, transparent 1.2px);
    background-size: 15px 15px;
  }

  .notes-label {
    font-family: var(--sans);
    font-size: 9px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
    margin-bottom: 10px;
    display: block;
  }

  /* NAGŁÓWKI I TYPOGRAFIA */
  h1, h2, h3 { font-family: var(--serif); font-weight: 700; color: var(--ink); margin-bottom: 1em; }
  .title { font-size: 42px; line-height: 1.1; margin-bottom: 20px; }
  .section-title { font-size: 28px; border-bottom: 2px solid var(--paper-mid); padding-bottom: 10px; margin-top: 30px; }
  
  .grad-type {
    background: var(--grad-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline;
  }

  p { margin-bottom: 1.4em; }

  /* STICKY NOTES (FIOLETOWE RAMKI) */
  .sticky-note {
    background: var(--purple-pale);
    border-radius: var(--radius);
    padding: 20px;
    margin: 25px 0;
    position: relative;
    box-shadow: 5px 5px 15px rgba(107, 53, 200, 0.05);
    border-left: 4px solid #6B35C8;
  }

  .sticky-note::after {
    content: 'Pamiętaj!';
    position: absolute;
    top: -10px;
    right: 20px;
    background: #6B35C8;
    color: white;
    font-size: 10px;
    font-weight: 800;
    padding: 4px 10px;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .sticky-note p { margin-bottom: 0; font-size: 12px; font-weight: 600; color: #371f5c; line-height: 1.5; }

  /* PAGINY */
  .runner {
    position: absolute;
    left: 18mm; right: 18mm;
    display: flex;
    justify-content: space-between;
    font-size: 9px;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 700;
  }
  .runner.top { top: 9mm; }
  .runner.bottom { bottom: 8mm; }

  @media print {
    body { background: white; }
    .page { box-shadow: none; margin: 0; page-break-after: always; }
  }
</style>
</head>
